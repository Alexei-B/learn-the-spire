# Decompiled game source — reference only, never committed (copyrighted)
refsrc/

# Copies of the game's binaries we reference at build time — never committed
lib/

# .NET build output
bin/
obj/
[Dd]ebug/
[Rr]elease/
*.user
*.suo
.vs/

# Test / regression artifacts that are environment-specific
TestResults/

# Python (lts2_agent reference package)
__pycache__/
*.pyc
.venv/
# Training artifacts (checkpoints, metric logs)
checkpoints/
*.msgpack
runs/
*.metrics.csv

# Local TUI agent config (machine-specific paths); commit lts2.agent.example.json instead
lts2.agent.json

# Derived card-metadata dump (from sts2.dll via --dump-cards)
python/lts2_agent/data/*
# ...but the oracle probe set (seeds + action indices + metadata only, no game content) is committed.
!python/lts2_agent/data/probes.json

# Transition corpus shards (logged game observations — large, regenerable, never committed)
python/data/corpus/
# Pre-tokenized corpus cache (derived from the corpus by lts2_agent.wm.cache; large, regenerable)
python/data/corpus_tok/
